cff-version: 1.2.0
title: "Project Protein: Bias-Audited Multimodal Sequence-Based Framework for Type 2 Diabetes Gene/Protein Prioritization"
message: "If you use this repository, please cite the associated manuscript and this repository."
type: software
authors:
  - family-names: "Nguyen"
    given-names: "Anh Khoa"
year: 2026
